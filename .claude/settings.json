{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(npm test)",
      "Bash(npm run test:watch)",
      "Bash(npm run test:coverage)",
      "Bash(npm run lint)",
      "Bash(npx jest --testPathPattern=*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Edit(./.devcontainer/*)",
      "Bash(npm install *)",
      "Bash(rm *)",
      "Bash(sudo *)"
    ]
  }
}
